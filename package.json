{
  "name": "serverless-api",
  "version": "1.0.0",
  "description": "AWS Lambda",
  "main": "src/handlers/getText.js",
  "scripts": {
    "deploy": "serverless deploy",
    "deploy:prod": "serverless deploy --stage prod",
    "remove": "serverless remove",
    "logs:text": "serverless logs -f getText -t",
    "logs:time": "serverless logs -f getTime -t",
    "invoke:text": "serverless invoke local -f getText",
    "invoke:time": "serverless invoke local -f getTime"
  },
  "dependencies": {
    "serverless": "^4.33.0"
  },
  "devDependencies": {
    "serverless-offline": "^14.5.0"
  }
}